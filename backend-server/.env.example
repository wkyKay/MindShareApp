# Copy this file to backend-server/.env and fill in real local secrets.

# Optional. Defaults to backend-server/forum.db.
DATABASE_URL=sqlite:///./forum.db

# Change this outside local development.
SECRET_KEY=dev-only-change-me

# Required for AI chat.
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

REDIS_URL=redis://localhost:6379/0

# Optional. Embedding API for RAG knowledge base retrieval.
# Leave EMBEDDING_MODEL empty to use BM25 keyword-only search.
# Use "baidu" for Wenxin Embedding-V1, or "openai" for OpenAI-compatible APIs.
EMBEDDING_PROVIDER=baidu
EMBEDDING_MODEL=embedding-v1
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=

# Required when EMBEDDING_PROVIDER=baidu.
BAIDU_API_KEY=your_baidu_api_key_here
BAIDU_SECRET_KEY=your_baidu_secret_key_here
BAIDU_WENXIN_BASE_URL=https://aip.baidubce.com/rpc/2.0/ai_custom/v1/wenxinworkshop
BAIDU_EMBEDDING_BATCH_SIZE=16

# Optional. Cross-encoder rerank for second-stage RAG ranking.
# Leave RERANKER_PROVIDER empty to use embedding/BM25 ranking only.
RERANKER_PROVIDER=
RERANKER_MODEL=BAAI/bge-reranker-base
RERANKER_CANDIDATE_K=30
RERANKER_BATCH_SIZE=16
