{
  "name": "react-app",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "i18n:apply:jsx": "tsx scripts/i18n-apply-jsx.ts",
    "i18n:migrate:literal-keys": "tsx scripts/i18n-migrate-literal-keys.ts",
    "i18n:scan": "tsx scripts/i18n-scan.ts",
    "i18n:sync": "tsx scripts/i18n-scan.ts --sync",
    "i18n:scan:warn": "tsx scripts/i18n-scan.ts || true",
    "check": "npm run typecheck && npm run i18n:scan"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/bottom-tabs": "^7.17.2",
    "@react-navigation/native": "^7.2.4",
    "@react-navigation/native-stack": "^7.15.1",
    "expo": "~54.0.0",
    "expo-document-picker": "~14.0.8",
    "expo-haptics": "~15.0.8",
    "expo-image-picker": "~16.0.0",
    "expo-localization": "^56.0.6",
    "expo-status-bar": "~3.0.0",
    "i18next": "^26.3.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-i18next": "^17.0.8",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-pager-view": "6.9.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-tab-view": "^4.3.0",
    "react-native-web": "~0.21.0",
    "streamdown-rn": "^0.2.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@babel/generator": "^7.29.7",
    "@babel/parser": "^7.29.7",
    "@babel/traverse": "^7.29.7",
    "@babel/types": "^7.29.7",
    "@types/babel__generator": "^7.27.0",
    "@types/babel__traverse": "^7.28.0",
    "@types/react": "~19.1.0",
    "fast-glob": "^3.3.3",
    "tsx": "^4.22.4",
    "typescript": "~5.9.2"
